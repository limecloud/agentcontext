{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://limecloud.github.io/agentcontext/schemas/agentcontext-event.schema.json",
  "title": "Agent Context Event",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "event_id": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "subject": {
      "type": "string"
    },
    "time": {
      "type": "string",
      "format": "date-time"
    },
    "context_id": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    },
    "policy_refs": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "telemetry_refs": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema_version",
    "event_id",
    "event_type",
    "source",
    "time"
  ]
}
