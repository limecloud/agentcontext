{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://limecloud.github.io/agentcontext/schemas/agentcontext-selection.schema.json",
  "title": "Agent Context Selection",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "selection_id": {
      "type": "string"
    },
    "surface_id": {
      "type": "string"
    },
    "query": {
      "type": "string"
    },
    "intent": {
      "type": "string"
    },
    "candidate_item_refs": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "selected_item_refs": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "omitted_item_refs": {
      "type": "array",
      "items": {
        "type": [
          "string",
          "object"
        ]
      }
    },
    "ranking_signals": {
      "type": "object",
      "additionalProperties": true
    },
    "selection_policy": {
      "type": [
        "string",
        "object"
      ]
    },
    "budget_ref": {
      "type": [
        "string",
        "object"
      ]
    },
    "rationale": {
      "type": "string"
    },
    "actor_ref": {
      "type": [
        "string",
        "object"
      ]
    },
    "model_ref": {
      "type": [
        "string",
        "object"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "schema_version",
    "selection_id",
    "surface_id",
    "created_at"
  ]
}
